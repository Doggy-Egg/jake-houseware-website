# env files (can opt-in for committing if needed)
.env*

# local runtime data (inquiries only; products.json is committed mock data)
/data/inquiries.json

# vercel
.vercel

# local planning / migration notes (not for repo)
supabase-plan.md

# typescript
*.tsbuildinfo
next-env.d.ts
